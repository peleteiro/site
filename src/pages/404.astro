---
import Layout from '../layouts/Layout.astro'
---

<Layout title="404 - Page not found">
  <div class="flex flex-col items-center justify-center text-center py-8">
    <div
      class="text-7xl font-bold bg-clip-text text-transparent bg-gradient-to-br from-indigo-500 to-purple-600 mb-6 drop-shadow-sm">
      404
    </div>
    <h1
      class="font-sans mb-4 text-slate-800 dark:text-slate-100 font-bold leading-tight tracking-tight mt-0 text-2xl sm:text-3xl">
      Page Not Found
    </h1>
    <p class="font-sans text-lg text-slate-500 dark:text-slate-400 mb-8 max-w-sm">
      We couldn't find what you were looking for. The page might have been moved or deleted.
    </p>
    <a
      href="/"
      class="inline-flex items-center justify-center px-6 py-3 rounded-full bg-slate-900 dark:bg-white text-white dark:text-slate-900 font-medium hover:bg-slate-800 dark:hover:bg-slate-100 hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200">
      Return Home
    </a>
  </div>
</Layout>
